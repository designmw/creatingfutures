---
export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
