---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(202 170 0);
    --aw-color-secondary: rgb(172 145 0);
    --aw-color-accent: rgb(202 170 0);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(33 33 33);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(202 170 0);
    --aw-color-secondary: rgb(172 145 0);
    --aw-color-accent: rgb(202 170 0);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 233 236);
    --aw-color-text-muted: rgb(229 233 236 / 66%);
    --aw-color-bg-page: rgb(33 33 33);

    ::selection {
      background-color: rgb(202 170 0);
      color: rgb(33 33 33);
    }
  }
</style>
