---
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/common/Breadcrumbs.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';
import portrait from '~/assets/images/caroline-kennedy-hero.jpg';

const qualifications = [
  'BA (Hons) Psychology',
  'MA in Social and Organisational Psychology',
  'Postgraduate Diploma in Career Education, Information and Guidance in Higher Education',
  'MBTI Certification',
  'EQ-i 2.0 / EQ360 Certification',
  'Accredited Strengths Profile Practitioner',
  'Member of the British Association of CV Writers (BACVW)',
  'Trained Interview Panel Member',
];

const metadata = {
  title: 'About Caroline Kennedy',
  description:
    'Caroline Kennedy is a qualified guidance professional, recruiter, CV writer and career coach with over 25 years of experience helping job seekers across Ireland.',
};
---

<Layout metadata={metadata}>
  {/* Black title band — alternates with the page background down the page. */}
  <section class="bg-black">
    <div class="px-4 pt-12 pb-14 sm:px-6 mx-auto lg:px-8 max-w-4xl">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

    <div class="mt-6 md:flex md:items-center md:gap-10">
      <div class="md:flex-1">
        <h1 class="font-bold font-heading text-4xl md:text-5xl tracking-tight">About me</h1>
        <p class="mt-4 text-xl text-muted">
          I'm Caroline Kennedy — a qualified guidance professional, recruiter, CV writer, experienced career coach and
          lecturer with over 25 years' career planning and recruitment experience.
        </p>
      </div>
      <div class="mt-8 md:mt-0 md:w-72 shrink-0">
        <Image
          src={portrait}
          alt="Caroline Kennedy, career coach and CV writer at Creating Futures"
          class="rounded-md w-full max-w-xs mx-auto"
          widths={[320, 576]}
          sizes="(max-width: 767px) 320px, 288px"
          width={288}
          height={288}
          loading="eager"
        />
      </div>
    </div>

    <h2 class="mt-12 font-bold font-heading text-3xl md:text-4xl">
      Only one person will get the job you're after — <span class="text-primary">you need an edge</span> to be that person
    </h2>
      <p class="mt-4 text-lg text-muted">
        Over the last two decades I have worked with thousands of job seekers and career transitioners, helping them
        realise their strengths, develop a personal brand, and clearly demonstrate their unique skills and value to
        prospective employers at every stage of the recruitment process.
      </p>
    </div>
  </section>

  <Features
    columns={3}
    items={[
      {
        title: 'Who I work with',
        description:
          'Senior, mid-career and entry-level clients, graduates and students who are ready to be intentional about their job search and invest in their career.',
        icon: 'tabler:users',
      },
      {
        title: 'What I do',
        description:
          'I write impactful and engaging CVs, cover letters and LinkedIn profiles, and help clients prepare for interview and understand their strengths and values.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Where I started',
        description:
          'I began my career in recruitment in London, recruiting senior finance and tax professionals, before moving into career guidance in Dublin 20 years ago.',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <section class="bg-black">
    <div class="px-4 py-12 sm:px-6 mx-auto lg:px-8 max-w-4xl md:py-16">
      <h2 class="font-bold font-heading text-3xl md:text-4xl">Expert support — not generic advice</h2>
    <p class="mt-4 text-lg text-muted">
      There's lots of free advice out there, but much of it is inaccurate or generic. Google doesn't offer tailored
      guidance based on a thorough understanding of your skills, experience and career aspirations.
    </p>
      <p class="mt-4 text-lg text-muted">
        To truly have the edge in a competitive employment market, you need expert support that helps you identify the
        right role, aligns your LinkedIn profile with your career goals, gets your CV noticed in a crowded inbox, and
        equips you to perform at a high level in interviews. Having worked closely with recruiters for 25 years, I
        understand what it takes to succeed at every stage of the hiring process.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 mx-auto lg:px-8 max-w-4xl md:py-16">
    <h2 class="font-bold font-heading text-3xl md:text-4xl text-center">Qualifications & certifications</h2>
    <ul class="mt-8 grid gap-x-10 gap-y-4 sm:grid-cols-2">
      {
        qualifications.map((qualification) => (
          <li class="flex items-start gap-3">
            <Icon name="tabler:certificate" class="w-6 h-6 shrink-0 text-primary mt-0.5" />
            <span class="text-lg text-muted">{qualification}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <CallToAction
    isDark
    title="Let's give you the edge"
    subtitle="I work with just 3–4 clients a month, so every client gets real attention. Send me a message about the role you're after, or connect with me on LinkedIn."
    actions={[
      { variant: 'primary', text: 'Make an inquiry', href: getPermalink('/contact') },
      {
        variant: 'secondary',
        text: 'View my LinkedIn',
        href: 'https://www.linkedin.com/in/carolinekennedycareers/',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  />
</Layout>
