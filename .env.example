# ── Brevo transactional email ─────────────────────────────────────────────────
# Required: your Brevo API key (Settings → SMTP & API → API Keys)
BREVO_API_KEY=

# Required: a verified sender address in your Brevo account
BREVO_SENDER_EMAIL=noreply@yourdomain.ie

# Optional: display name for the sender (defaults to business.name in business.ts)
BREVO_SENDER_NAME=

# Required: the inbox that receives contact form submissions
CONTACT_TO_EMAIL=hello@yourdomain.ie

# Optional: recipient display name (defaults to business.name in business.ts)
CONTACT_TO_NAME=

# ── Cloudflare Turnstile (optional bot protection on the contact form) ────────
# Leave both blank to disable Turnstile (the honeypot still runs). To enable,
# create a Turnstile widget at dash.cloudflare.com → Turnstile.
# Public site key — safe to expose; inlined into the page at build time.
PUBLIC_TURNSTILE_SITE_KEY=
# Secret key — set as a Worker secret in production (`wrangler secret put
# TURNSTILE_SECRET_KEY`); the .env value here is only for local `astro dev`.
TURNSTILE_SECRET_KEY=

# ── Site ──────────────────────────────────────────────────────────────────────
# Set the canonical site URL (also set in src/config.yaml)
# SITE_URL=https://yourdomain.ie
